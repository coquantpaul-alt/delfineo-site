---
import Base from '../../layouts/Base.astro';
import AuthScript from '../../components/AuthScript.astro';
import { t } from '../../i18n.js';
import { metaFor, META_KEYS, META_LABELS } from '../../lib/meta-sections.js';
import { getCollection } from 'astro:content';

const lang = 'fr';
const altLang = 'en';
const i = (key) => t(lang, key);
const L = META_LABELS[lang];

const allResearch = await getCollection('research', ({ id }) => id.startsWith(`${lang}/`));
const allNews = await getCollection('news', ({ id }) => id.startsWith(`${lang}/`));

const MO = {january:1,february:2,march:3,april:4,may:5,june:6,july:7,august:8,september:9,october:10,november:11,december:12,janvier:1,'février':2,mars:3,avril:4,mai:5,juin:6,juillet:7,'août':8,septembre:9,octobre:10,novembre:11,'décembre':12};
const researchDate = (s) => { const [m, y] = s.split(' '); return parseInt(y) * 12 + (MO[m.toLowerCase()] || 0); };
const research = allResearch.sort((a, b) => {
  const da = researchDate(a.data.date), db = researchDate(b.data.date);
  if (da !== db) return db - da;
  return a.data.title.localeCompare(b.data.title);
});
const news = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Today's date (for "Aujourd'hui" label and badge count)
const today = new Date().toISOString().slice(0, 10);
const todayCount = news.filter((item) => item.data.date === today).length;

const newsByDate = {};
for (const item of news) {
  const d = item.data.date;
  if (!newsByDate[d]) newsByDate[d] = { date: d, dateDisplay: item.data.dateDisplay, items: [] };
  newsByDate[d].items.push(item);
}
const newsGroups = Object.values(newsByDate);

// Meta-section counts (for chip labels)
const metaCounts = { markets:0, corp:0, tech:0, energy:0, geo:0, macro:0 };
for (const item of news) metaCounts[metaFor(item.data.category)]++;
---

<Base title="Delfineo — Recherche & Actualités en Investissement Value" lang={lang}>
  <header class="site-header">
    <a href={`/${lang}/`} class="site-logo">
      <h1>DELFINEO</h1>
      <p class="tagline">{i('tagline')}</p>
    </a>
    <nav class="nav">
      <button class="tab-btn active" id="tab-news" onclick="showTab('news')">
        {i('news')} {todayCount > 0 && <span class="tab-badge">{todayCount}</span>}
      </button>
      <button class="tab-btn" id="tab-research" onclick="showTab('research')">
        {i('research')}
      </button>
      <span class="nav-divider"></span>
      <div class="lang-toggle">
        <a href={`/${altLang}/`} style="text-decoration:none"><span>EN</span></a>
        <span class="sep">/</span>
        <span class="active">FR</span>
      </div>
      <span class="nav-divider"></span>
      <div id="user-area" class="user-badge" data-signout={i('signOut')} style="display:none"></div>
      <button class="btn-subscribe" data-subscribe>{i('subscribe')}</button>
    </nav>
  </header>

  <main style="max-width:800px;margin:0 auto;padding:20px 48px 100px;">
    <div id="panel-news" class="fade-in">
      <div class="section-header" style="margin-bottom:16px">
        <h2>{i('newsTitle')}</h2>
      </div>

      <!-- Filtre par rubrique -->
      <div class="chip-bar" id="chip-bar" role="tablist" aria-label="Filtrer par rubrique">
        <button class="chip active" data-meta="all" role="tab" aria-selected="true">{L.all} <span class="chip-count">{news.length}</span></button>
        {META_KEYS.map((k) => (
          <button class="chip" data-meta={k} role="tab" aria-selected="false">{L[k]} <span class="chip-count">{metaCounts[k]}</span></button>
        ))}
      </div>
      <p class="result-bar" id="result-bar" aria-live="polite"></p>

      {newsGroups.map((group) => (
        <div class="day-block" data-day={group.date} style="margin-bottom:44px">
          <div class="news-day-header">
            <span class="day-label">{group.date === today ? "Aujourd'hui" : group.dateDisplay}</span>
            <span class="day-date">{group.dateDisplay}</span>
          </div>
          {group.items.map((item) => (
            <a href={`/${lang}/news/${item.slug.replace(`${lang}/`, '')}/`} class="news-item" data-gated data-meta={metaFor(item.data.category)}>
              <div class="meta">
                <span class="category">{item.data.category}</span>
                <span class="lock-badge lock-badge-sm">✉</span>
              </div>
              <h3>{item.data.title}</h3>
              <p>{item.data.summary}</p>
            </a>
          ))}
          <p class="empty-state hidden">Aucun article dans cette rubrique le {group.dateDisplay}.</p>
        </div>
      ))}
    </div>

    <div id="panel-research" class="fade-in" style="display:none">
      <div class="section-header" style="margin-bottom:8px">
        <p class="label">{i('researchLabel')}</p>
        <h2>{i('researchTitle')}</h2>
        <p>{i('researchSub')}</p>
      </div>
      {research.map((article) => (
        <a href={`/${lang}/research/${article.slug.replace(`${lang}/`, '')}/`} class="research-card" data-gated>
          <div class="meta">
            <span class="category">{article.data.category}</span>
            <span class="date">{article.data.date}</span>
            <span class="read-time">{article.data.readTime}</span>
            <span class="lock-badge">{i('emailToRead')}</span>
          </div>
          <h2>{article.data.title}</h2>
          <p>{article.data.subtitle}</p>
        </a>
      ))}
    </div>

    <section class="about-section">
      <h3>{i('aboutTitle')}</h3>
      <p>{i('about1')}</p>
      <p>{i('about2')}</p>
      <p>{i('about3')}</p>
    </section>
  </main>

  <footer class="site-footer">
    <span>{i('copy')}</span>
    <span>{i('disclaimer')}</span>
  </footer>

  <div id="auth-overlay" class="auth-overlay" style="display:none">
    <div class="auth-modal">
      <button id="auth-close" class="close">×</button>
      <div class="bar"></div>
      <div id="auth-form-state">
        <h2>{i('authTitle')}</h2>
        <p class="desc">{i('authDesc')}</p>
        <p class="hint">{i('authHint')}</p>
        <div class="auth-form">
          <input id="auth-email" type="email" placeholder="votre@email.com" />
          <button id="auth-btn" data-label={i('authBtn')} data-checking={i('authChecking')}>{i('authBtn')}</button>
        </div>
        <p id="auth-error" class="auth-error" data-email-error={i('authErrorEmail')}></p>
        <p class="auth-footer">{i('authFree')}</p>
      </div>
      <div id="auth-success-state" class="auth-success" style="display:none">
        <div class="check">✓</div>
        <h2 id="success-title" data-existing={i('authWelcomeBack')} data-new={i('authWelcomeNew')}></h2>
        <p id="success-msg" data-existing={i('authMsgExisting')} data-new={i('authMsgNew')}></p>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ labels: L }}>
    function showTab(tab) {
      document.getElementById('panel-news').style.display = tab === 'news' ? 'block' : 'none';
      document.getElementById('panel-research').style.display = tab === 'research' ? 'block' : 'none';
      document.getElementById('tab-news').classList.toggle('active', tab === 'news');
      document.getElementById('tab-research').classList.toggle('active', tab === 'research');
      const url = new URL(window.location);
      url.searchParams.set('tab', tab);
      history.replaceState(null, '', url);
    }
    // Expose to window so inline onclick="showTab(...)" handlers still find it
    // (define:vars wraps this script in a local scope)
    window.showTab = showTab;

    // ── Filtre par rubrique ──
    function applyFilter(meta, updateUrl) {
      const chipBar = document.getElementById('chip-bar');
      const resultBar = document.getElementById('result-bar');
      if (!chipBar) return;

      const chips = chipBar.querySelectorAll('.chip');
      chips.forEach(c => {
        const on = c.dataset.meta === meta;
        c.classList.toggle('active', on);
        c.setAttribute('aria-selected', on ? 'true' : 'false');
      });

      const items = document.querySelectorAll('#panel-news .news-item');
      let shown = 0;
      items.forEach(it => {
        const match = meta === 'all' || it.dataset.meta === meta;
        it.classList.toggle('hidden', !match);
        if (match) shown++;
      });

      document.querySelectorAll('#panel-news .day-block').forEach(block => {
        const visible = block.querySelectorAll('.news-item:not(.hidden)').length;
        const empty = block.querySelector('.empty-state');
        if (empty) empty.classList.toggle('hidden', visible > 0);
      });

      if (resultBar) {
        if (meta === 'all') {
          resultBar.textContent = '';
          resultBar.classList.remove('on');
        } else {
          const name = labels[meta] || meta;
          resultBar.textContent = shown === 1
            ? `1 article dans ${name}`
            : `${shown} articles dans ${name}`;
          resultBar.classList.add('on');
        }
      }

      if (updateUrl !== false) {
        const url = new URL(window.location);
        if (meta === 'all') url.searchParams.delete('section');
        else url.searchParams.set('section', meta);
        history.replaceState(null, '', url);
      }
    }

    (function() {
      const params = new URLSearchParams(window.location.search);
      const t = params.get('tab');
      if (t === 'research' || t === 'news') showTab(t);
      const s = params.get('section');
      if (s) applyFilter(s, false);
    })();

    document.addEventListener('click', function(e) {
      const chip = e.target.closest('#chip-bar .chip');
      if (!chip) return;
      e.preventDefault();
      applyFilter(chip.dataset.meta, true);
    });
  </script>
  <AuthScript />
</Base>
