---
import Base from '../../../layouts/Base.astro';
import AuthScript from '../../../components/AuthScript.astro';
import { getCollection } from 'astro:content';

const lang = 'fr';

// Fetch every news AND research item so the client-side script can
// render any saved item without an extra fetch. `kind` lets the
// renderer pick the right URL prefix and category styling.
const newsItems = await getCollection('news',     ({ id }) => id.startsWith('fr/'));
const resItems  = await getCollection('research', ({ id }) => id.startsWith('fr/'));
const data = [
  ...newsItems.map((it) => ({
    kind: 'news',
    slug: it.slug.replace('fr/', ''),
    title: it.data.title,
    category: it.data.category,
    date: it.data.date,
    dateDisplay: it.data.dateDisplay,
  })),
  ...resItems.map((it) => ({
    kind: 'research',
    slug: it.slug.replace('fr/', ''),
    title: it.data.title,
    category: it.data.category,
    date: it.data.date,
    dateDisplay: it.data.date,
  })),
];
---

<Base
  title="Articles sauvegardés — Delfineo"
  description="Vos articles Delfineo sauvegardés."
  lang={lang}
  active="saved"
  altPath="/en/saved/"
>
  <div class="saved-page">
    <div class="saved-page-head">
      <a href={`/${lang}/`} class="saved-back">← Retour</a>
      <h1>Articles sauvegardés</h1>
    </div>

    <div
      id="saved-list"
      class="saved-list"
      data-news={JSON.stringify(data)}
      data-empty-title="Aucun article sauvegardé"
      data-empty-body="Touchez l'icône signet en haut d'un article pour le sauvegarder."
      data-label-today="Aujourd'hui"
      data-label-yesterday="Hier"
      data-label-week="Cette semaine"
      data-label-month="Ce mois-ci"
      data-label-older="Plus ancien"
      data-label-remove="Retirer"
    >
      <p class="saved-empty">Chargement…</p>
    </div>
  </div>

  <AuthScript />
</Base>

<script is:inline>
  (function () {
    const root = document.getElementById('saved-list');
    if (!root) return;

    const KEY  = 'delfineo:saved';
    const LANG = document.documentElement.lang || 'fr';

    const ALL = (() => {
      try { return JSON.parse(root.dataset.news || '[]'); }
      catch (_) { return []; }
    })();
    const itemsByKey = Object.create(null);
    const keyOf = (kind, slug) => (kind || 'news') + '/' + slug;
    ALL.forEach((n) => { itemsByKey[keyOf(n.kind, n.slug)] = n; });

    const labels = {
      today:     root.dataset.labelToday     || "Aujourd'hui",
      yesterday: root.dataset.labelYesterday || 'Hier',
      week:      root.dataset.labelWeek      || 'Cette semaine',
      month:     root.dataset.labelMonth     || 'Ce mois-ci',
      older:     root.dataset.labelOlder     || 'Plus ancien',
      remove:    root.dataset.labelRemove    || 'Retirer',
    };

    const readList = () => {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]') || []; }
      catch (_) { return []; }
    };
    const writeList = (list) => {
      try { localStorage.setItem(KEY, JSON.stringify(list)); } catch (_) {}
    };

    function startOfDay(ts) {
      const d = new Date(ts);
      d.setHours(0, 0, 0, 0);
      return d.getTime();
    }
    function bucketFor(savedAt, todayStart) {
      const diff = todayStart - startOfDay(savedAt);
      if (diff <= 0)            return 'today';
      if (diff <= 86400000)     return 'yesterday';
      if (diff <= 7 * 86400000) return 'week';
      if (diff <= 30 * 86400000) return 'month';
      return 'older';
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
      }[c]));
    }

    function render() {
      const list = readList()
        .filter((it) => it && it.slug && itemsByKey[keyOf(it.kind, it.slug)])
        .sort((a, b) => (b.savedAt || 0) - (a.savedAt || 0));

      if (list.length === 0) {
        root.innerHTML =
          '<div class="saved-empty">' +
            '<h2>' + escapeHtml(root.dataset.emptyTitle || '') + '</h2>' +
            '<p>'  + escapeHtml(root.dataset.emptyBody  || '') + '</p>' +
          '</div>';
        return;
      }

      const todayStart = startOfDay(Date.now());
      const groups = { today: [], yesterday: [], week: [], month: [], older: [] };
      list.forEach((it) => {
        groups[bucketFor(it.savedAt || Date.now(), todayStart)].push(it);
      });

      const order = ['today', 'yesterday', 'week', 'month', 'older'];
      let html = '';
      order.forEach((k) => {
        if (groups[k].length === 0) return;
        html += '<div class="saved-group">';
        html += '<h2 class="saved-group-head">' + escapeHtml(labels[k]) + '</h2>';
        groups[k].forEach((it) => {
          const n = itemsByKey[keyOf(it.kind, it.slug)];
          const itemKind = n.kind || 'news';
          const href = '/' + LANG + '/' + itemKind + '/' + n.slug + '/';
          const eyebrow = itemKind === 'research'
            ? 'ANALYSE · ' + escapeHtml(n.category)
            : escapeHtml(n.category);
          html +=
            '<a class="saved-item" href="' + href + '" data-kind="' + itemKind + '">' +
              '<span class="saved-item-cat">' + eyebrow + '</span>' +
              '<h3 class="saved-item-title">' + escapeHtml(n.title) + '</h3>' +
              '<span class="saved-item-date">' + escapeHtml(n.dateDisplay || '') + '</span>' +
              '<button type="button" class="saved-item-remove" ' +
                'data-remove-slug="' + escapeHtml(n.slug) + '" ' +
                'data-remove-kind="' + itemKind + '" ' +
                'aria-label="' + escapeHtml(labels.remove) + '">' +
                '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">' +
                  '<path d="M6 4h12v17l-6-4-6 4z"/>' +
                '</svg>' +
              '</button>' +
            '</a>';
        });
        html += '</div>';
      });

      root.innerHTML = html;
    }

    root.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-remove-slug]');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const slug = btn.dataset.removeSlug;
      const kind = btn.dataset.removeKind || 'news';
      const list = readList().filter((it) =>
        !(it && it.slug === slug && (it.kind || 'news') === kind)
      );
      writeList(list);
      render();
      if (document.body.classList.contains('is-signed-in')) {
        fetch('/api/auth/saved', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ slug, kind }),
        }).catch(() => {});
      }
    });

    document.addEventListener('delfineo:saved-synced', render);

    render();
  })();
</script>

<style>
  .saved-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px var(--pad-x) 80px;
  }
  .saved-page-head { margin-bottom: 24px; }
  .saved-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
    text-decoration: none;
    margin-bottom: 14px;
  }
  .saved-back:hover { color: var(--navy); }
  .saved-page h1 {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .saved-empty {
    margin: 48px 0;
    text-align: center;
    color: var(--muted-2);
  }
  .saved-empty h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .saved-empty p {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 auto;
    max-width: 360px;
  }

  .saved-group { margin-top: 26px; }
  .saved-group-head {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 1px dotted var(--rule-strong);
  }

  .saved-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
    position: relative;
  }
  .saved-item:last-child { border-bottom: none; }
  .saved-item-cat {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7a2e3b;
    margin-bottom: 4px;
  }
  .saved-item-title {
    grid-column: 1;
    grid-row: 2;
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.3;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.005em;
  }
  .saved-item-date { display: none; }
  .saved-item-remove {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
    justify-self: end;
    margin-top: 2px;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; border: none; padding: 0;
    color: #7a2e3b;
    cursor: pointer;
  }
  .saved-item-remove svg { width: 18px; height: 18px; }
  .saved-item-remove:hover { color: var(--navy); }

  @media (max-width: 640px) {
    .saved-page { padding: 18px 18px 90px; }
    .saved-page h1 { font-size: 24px; }
    .saved-item-title { font-size: 16px; }
  }
</style>
