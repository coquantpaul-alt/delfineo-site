---
import Base from '../../../layouts/Base.astro';
import AuthScript from '../../../components/AuthScript.astro';
import { t } from '../../../i18n.js';
import { getCollection } from 'astro:content';

const lang = 'en';
const i = (key) => t(lang, key);

export async function getStaticPaths() {
  const items = await getCollection('news', ({ id }) => id.startsWith('en/'));
  return items.map((item) => ({
    params: { slug: item.slug.replace('en/', '') },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<Base title={`${item.data.title} — Delfineo`} description={item.data.summary.slice(0, 160)} lang={lang}>
  <header class="site-header">
    <a href={`/${lang}/`} class="site-logo">
      <h1>DELFINEO</h1>
      <p class="tagline">{i('tagline')}</p>
    </a>
    <nav class="nav">
      <a href={`/${lang}/`} class="tab-btn">{i('news')}</a>
      <a href={`/${lang}/`} class="tab-btn">{i('research')}</a>
      <span class="nav-divider"></span>
      <div class="lang-toggle">
        <span class="active">EN</span>
        <span class="sep">/</span>
        <a href={`/fr/news/${item.slug.replace('en/', '')}/`} style="text-decoration:none"><span>FR</span></a>
      </div>
      <span class="nav-divider"></span>
      <div id="user-area" class="user-badge" data-signout={i('signOut')} style="display:none"></div>
      <button class="btn-subscribe" data-subscribe>{i('subscribe')}</button>
    </nav>
  </header>

  <main class="content-article" style="padding:40px 24px 80px;">
    <a href={`/${lang}/`} class="article-back">{i('backNews')}</a>

    <div class="article-detail">
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap">
        <span style="font-family:var(--font-sans);font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent)">{item.data.category}</span>
        <span style="font-family:var(--font-sans);font-size:0.72rem;color:var(--text-dim)">{item.data.dateDisplay}</span>
      </div>

      <h1 class="news">{item.data.title}</h1>

      <!-- Summary -->
      <div style="margin-bottom:36px;margin-top:32px">
        <p class="summary-label">{i('summary')}</p>
        <p style="font-family:var(--font-serif);font-size:1.04rem;color:var(--text-mid);line-height:1.82;margin:0">{item.data.summary}</p>
      </div>

      <!-- Delfineo's Take -->
      {item.data.insight && (
        <div class="take-block">
          <p class="label">{i('take')}</p>
          <p>{item.data.insight}</p>
        </div>
      )}
    </div>
  </main>

  <footer class="site-footer">
    <span>{i('copy')}</span>
    <span>{i('disclaimer')}</span>
  </footer>

  <div id="auth-overlay" class="auth-overlay" style="display:none">
    <div class="auth-modal">
      <button id="auth-close" class="close">×</button>
      <div class="bar"></div>
      <div id="auth-form-state">
        <h2>{i('authTitle')}</h2>
        <p class="desc">{i('authDesc')}</p>
        <p class="hint">{i('authHint')}</p>
        <div class="auth-form">
          <input id="auth-email" type="email" placeholder="your@email.com" />
          <button id="auth-btn" data-label={i('authBtn')} data-checking={i('authChecking')}>{i('authBtn')}</button>
        </div>
        <p id="auth-error" class="auth-error" data-email-error={i('authErrorEmail')}></p>
        <p class="auth-footer">{i('authFree')}</p>
      </div>
      <div id="auth-success-state" class="auth-success" style="display:none">
        <div class="check">✓</div>
        <h2 id="success-title" data-existing={i('authWelcomeBack')} data-new={i('authWelcomeNew')}></h2>
        <p id="success-msg" data-existing={i('authMsgExisting')} data-new={i('authMsgNew')}></p>
      </div>
    </div>
  </div>

  <AuthScript />
</Base>
