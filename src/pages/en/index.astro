---
import Base from '../../layouts/Base.astro';
import AuthScript from '../../components/AuthScript.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import IranOutlookChart from '../../components/visuals/IranOutlookChart.astro';
import MunitionsChart from '../../components/visuals/MunitionsChart.astro';
import EditorialFilters from '../../components/editorial/EditorialFilters.astro';
import EditorialStoryRow from '../../components/editorial/EditorialStoryRow.astro';
import ResearchHero from '../../components/editorial/ResearchHero.astro';
import ResearchRow from '../../components/editorial/ResearchRow.astro';
import DateHead from '../../components/editorial/DateHead.astro';
import { metaFor, META_KEYS, META_LABELS } from '../../lib/meta-sections.js';
import { getCollection } from 'astro:content';

const lang = 'en';
const L = META_LABELS[lang];

// ── Fetch ──────────────────────────────────────────────────────────
const allResearch = await getCollection('research', ({ id }) => id.startsWith(`${lang}/`));
const allNews     = await getCollection('news',     ({ id }) => id.startsWith(`${lang}/`));

// ── Sort ───────────────────────────────────────────────────────────
const MO: Record<string, number> = {
  january:1,february:2,march:3,april:4,may:5,june:6,july:7,august:8,september:9,october:10,november:11,december:12,
  janvier:1,'février':2,mars:3,avril:4,mai:5,juin:6,juillet:7,'août':8,septembre:9,octobre:10,novembre:11,'décembre':12,
};
const researchDate = (s: string) => { const [m, y] = s.split(' '); return parseInt(y) * 12 + (MO[m.toLowerCase()] || 0); };
const research = allResearch.sort((a, b) => {
  const da = researchDate(a.data.date), db = researchDate(b.data.date);
  if (da !== db) return db - da;
  return a.data.title.localeCompare(b.data.title);
});
const news = allNews.sort((a, b) => {
  const dt = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  if (dt !== 0) return dt;
  return (a.data.order ?? 999) - (b.data.order ?? 999);
});

// ── Hero picks ─────────────────────────────────────────────────────
const [heroNews, ...restNews] = news;
const [heroResearch, ...restResearch] = research;

// ── Today / dates ──────────────────────────────────────────────────
const today = new Date().toISOString().slice(0, 10);
const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
const todayCount = news.filter((it) => it.data.date === today).length;

// ── Group news by date ─────────────────────────────────────────────
const newsByDate: Record<string, { date: string; dateDisplay: string; items: typeof news }> = {};
for (const item of restNews) {
  const d = item.data.date;
  if (!newsByDate[d]) newsByDate[d] = { date: d, dateDisplay: item.data.dateDisplay, items: [] };
  newsByDate[d].items.push(item);
}
const newsGroups = Object.values(newsByDate);

// Section counts (for chip filter — include the hero so totals are right)
const metaCounts: Record<string, number> = { markets:0, corp:0, tech:0, energy:0, geo:0, macro:0 };
for (const item of news) metaCounts[metaFor(item.data.category)]++;

// Running index for "No 02, 03, …" next to story rows
let rowNum = 1;  // hero is No 01
---

<Base
  title="Delfineo — Value Investing Research & News"
  lang={lang}
  active="news"
  newsCount={todayCount > 0 ? todayCount : null}
  researchCount={research.length}
  altPath="/fr/"
>
  <!-- NEWS TAB ───────────────────────────────────────────────── -->
  <div id="panel-news" class="fade-in">
    {heroNews && (
      <EditorialHero story={heroNews} lang={lang} readMinutes={4}>
        {heroNews.slug.endsWith('central-banks-hold') && (
          <IranOutlookChart slot="aside" lang={lang} variant="hero" />
        )}
        {heroNews.slug.endsWith('us-munitions-low') && (
          <MunitionsChart slot="aside" lang={lang} variant="hero" />
        )}
      </EditorialHero>
    )}

    <EditorialFilters lang={lang} totalCount={news.length} counts={metaCounts} />
    <p class="result-bar" id="result-bar" aria-live="polite"></p>

    {/* Today */}
    {newsGroups.filter((g) => g.date === today).map((group) => {
      rowNum = 1;
      return (
        <div class="day-block" data-day={group.date}>
          <DateHead label="Today" date={group.dateDisplay} day={group.date} />
          {group.items.map((item) => (
            <EditorialStoryRow story={item} num={++rowNum} lang={lang} />
          ))}
          <p class="empty-state hidden" style="padding:18px var(--pad-x) 6px;color:var(--muted);font-family:var(--font-display);font-style:italic;font-size:14px;">No stories in this section on {group.dateDisplay}.</p>
        </div>
      );
    })}

    {/* Yesterday + earlier */}
    {newsGroups.filter((g) => g.date !== today).map((group) => (
      <div class="day-block" data-day={group.date}>
        <DateHead
          label={group.date === yesterday ? 'Yesterday' : group.dateDisplay}
          date={group.dateDisplay}
          day={group.date}
        />
        {group.items.map((item) => (
          <EditorialStoryRow story={item} num={++rowNum} lang={lang} />
        ))}
        <p class="empty-state hidden" style="padding:18px var(--pad-x) 6px;color:var(--muted);font-family:var(--font-display);font-style:italic;font-size:14px;">No stories in this section on {group.dateDisplay}.</p>
      </div>
    ))}
  </div>

  <!-- RESEARCH TAB ──────────────────────────────────────────── -->
  <div id="panel-research" class="fade-in" style="display:none">
    {heroResearch && (
      <ResearchHero piece={heroResearch} lang={lang} />
    )}

    {/* Simple coverage filter nav */}
    <nav class="editorial-filters" role="tablist" aria-label="Research coverage">
      <span class="label">Coverage</span>
      <span class="vdivider"></span>
      <button class="chip active">All reports<sup class="chip-count">{research.length}</sup></button>
    </nav>

    <DateHead label="Archive" date={`${research.length} reports`} />

    {restResearch.map((p, i) => (
      <ResearchRow piece={p} num={i + 2} lang={lang} />
    ))}
  </div>

  <!-- Tab + filter scripts ──────────────────────────────────── -->
  <script is:inline define:vars={{ labels: L }}>
    function showTab(tab) {
      document.getElementById('panel-news').style.display = tab === 'news' ? 'block' : 'none';
      document.getElementById('panel-research').style.display = tab === 'research' ? 'block' : 'none';
      document.getElementById('tab-news').classList.toggle('active', tab === 'news');
      document.getElementById('tab-research').classList.toggle('active', tab === 'research');
      const url = new URL(window.location);
      url.searchParams.set('tab', tab);
      history.replaceState(null, '', url);
    }
    window.showTab = showTab;

    function applyFilter(meta, updateUrl) {
      const chipBar = document.getElementById('chip-bar');
      const resultBar = document.getElementById('result-bar');
      if (!chipBar) return;

      chipBar.querySelectorAll('.chip').forEach((c) => {
        const on = c.dataset.meta === meta;
        c.classList.toggle('active', on);
        c.setAttribute('aria-selected', on ? 'true' : 'false');
      });

      const items = document.querySelectorAll('#panel-news .story-row');
      let shown = 0;
      items.forEach((it) => {
        const match = meta === 'all' || it.dataset.meta === meta;
        it.style.display = match ? '' : 'none';
        if (match) shown++;
      });

      document.querySelectorAll('#panel-news .day-block').forEach((block) => {
        const visible = Array.from(block.querySelectorAll('.story-row')).filter((it) => it.style.display !== 'none').length;
        const empty = block.querySelector('.empty-state');
        if (empty) empty.classList.toggle('hidden', visible > 0);
      });

      if (resultBar) {
        if (meta === 'all') {
          resultBar.textContent = '';
          resultBar.classList.remove('on');
        } else {
          const name = labels[meta] || meta;
          resultBar.textContent = shown === 1
            ? `Showing 1 story in ${name}`
            : `Showing ${shown} stories in ${name}`;
          resultBar.classList.add('on');
        }
      }

      if (updateUrl !== false) {
        const url = new URL(window.location);
        if (meta === 'all') url.searchParams.delete('section');
        else url.searchParams.set('section', meta);
        history.replaceState(null, '', url);
      }
    }

    (function () {
      const params = new URLSearchParams(window.location.search);
      const t = params.get('tab');
      if (t === 'research' || t === 'news') showTab(t);
      const s = params.get('section');
      if (s) applyFilter(s, false);
    })();

    document.addEventListener('click', (e) => {
      const chip = e.target.closest('#chip-bar .chip');
      if (!chip) return;
      e.preventDefault();
      applyFilter(chip.dataset.meta, true);
    });
  </script>

  <AuthScript />
</Base>
