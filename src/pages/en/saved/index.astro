---
import Base from '../../../layouts/Base.astro';
import AuthScript from '../../../components/AuthScript.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

// Fetch every news article so the client-side script can render any
// saved item without an extra fetch. Strip the en/ prefix from the
// slug so it matches what we store in localStorage.
const items = await getCollection('news', ({ id }) => id.startsWith('en/'));
const data = items.map((it) => ({
  slug: it.slug.replace('en/', ''),
  title: it.data.title,
  category: it.data.category,
  date: it.data.date,
  dateDisplay: it.data.dateDisplay,
}));
---

<Base
  title="Saved stories — Delfineo"
  description="Your saved Delfineo stories."
  lang={lang}
  active="saved"
  altPath="/fr/saved/"
>
  <div class="saved-page">
    <div class="saved-page-head">
      <a href={`/${lang}/`} class="saved-back">← Back</a>
      <h1>Saved stories</h1>
    </div>

    <div
      id="saved-list"
      class="saved-list"
      data-news={JSON.stringify(data)}
      data-empty-title="No saved stories yet"
      data-empty-body="Tap the bookmark icon at the top of any article to save it for later."
      data-label-today="Today"
      data-label-yesterday="Yesterday"
      data-label-week="Earlier this week"
      data-label-month="Earlier this month"
      data-label-older="Older"
      data-label-remove="Remove"
    >
      <p class="saved-empty">Loading…</p>
    </div>
  </div>

  <AuthScript />
</Base>

<script is:inline>
  (function () {
    const root = document.getElementById('saved-list');
    if (!root) return;

    const KEY  = 'delfineo:saved';
    const LANG = document.documentElement.lang || 'en';

    const NEWS = (() => {
      try { return JSON.parse(root.dataset.news || '[]'); }
      catch (_) { return []; }
    })();
    const newsBySlug = Object.create(null);
    NEWS.forEach((n) => { newsBySlug[n.slug] = n; });

    const labels = {
      today:     root.dataset.labelToday     || 'Today',
      yesterday: root.dataset.labelYesterday || 'Yesterday',
      week:      root.dataset.labelWeek      || 'Earlier this week',
      month:     root.dataset.labelMonth     || 'Earlier this month',
      older:     root.dataset.labelOlder     || 'Older',
      remove:    root.dataset.labelRemove    || 'Remove',
    };

    const readList = () => {
      try { return JSON.parse(localStorage.getItem(KEY) || '[]') || []; }
      catch (_) { return []; }
    };
    const writeList = (list) => {
      try { localStorage.setItem(KEY, JSON.stringify(list)); } catch (_) {}
    };

    function startOfDay(ts) {
      const d = new Date(ts);
      d.setHours(0, 0, 0, 0);
      return d.getTime();
    }
    function bucketFor(savedAt, todayStart) {
      const diff = todayStart - startOfDay(savedAt);
      if (diff <= 0)            return 'today';
      if (diff <= 86400000)     return 'yesterday';
      if (diff <= 7 * 86400000) return 'week';
      if (diff <= 30 * 86400000) return 'month';
      return 'older';
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
      }[c]));
    }

    function render() {
      const list = readList()
        .filter((it) => it && it.slug && newsBySlug[it.slug])
        .sort((a, b) => (b.savedAt || 0) - (a.savedAt || 0));

      if (list.length === 0) {
        root.innerHTML =
          '<div class="saved-empty">' +
            '<h2>' + escapeHtml(root.dataset.emptyTitle || 'No saved stories yet') + '</h2>' +
            '<p>'  + escapeHtml(root.dataset.emptyBody  || '') + '</p>' +
          '</div>';
        return;
      }

      const todayStart = startOfDay(Date.now());
      const groups = { today: [], yesterday: [], week: [], month: [], older: [] };
      list.forEach((it) => {
        groups[bucketFor(it.savedAt || Date.now(), todayStart)].push(it);
      });

      const order = ['today', 'yesterday', 'week', 'month', 'older'];
      let html = '';
      order.forEach((k) => {
        if (groups[k].length === 0) return;
        html += '<div class="saved-group">';
        html += '<h2 class="saved-group-head">' + escapeHtml(labels[k]) + '</h2>';
        groups[k].forEach((it) => {
          const n = newsBySlug[it.slug];
          const href = '/' + LANG + '/news/' + n.slug + '/';
          html +=
            '<a class="saved-item" href="' + href + '">' +
              '<span class="saved-item-cat">' + escapeHtml(n.category) + '</span>' +
              '<h3 class="saved-item-title">' + escapeHtml(n.title) + '</h3>' +
              '<span class="saved-item-date">' + escapeHtml(n.dateDisplay || '') + '</span>' +
              '<button type="button" class="saved-item-remove" data-remove="' + escapeHtml(n.slug) + '" aria-label="' + escapeHtml(labels.remove) + '">' +
                '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">' +
                  '<path d="M6 4h12v17l-6-4-6 4z"/>' +
                '</svg>' +
              '</button>' +
            '</a>';
        });
        html += '</div>';
      });

      root.innerHTML = html;
    }

    // Delegate clicks on the unsave button — stop the link from
    // navigating, mutate localStorage, mirror to backend if signed
    // in, then re-render.
    root.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-remove]');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const slug = btn.dataset.remove;
      const list = readList().filter((it) => it && it.slug !== slug);
      writeList(list);
      render();
      if (document.body.classList.contains('is-signed-in')) {
        fetch('/api/auth/saved', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ slug }),
        }).catch(() => {});
      }
    });

    // AuthScript dispatches this after merging cloud saves into
    // localStorage on page load, so the list reflects bookmarks
    // made on another device.
    document.addEventListener('delfineo:saved-synced', render);

    render();
  })();
</script>

<style>
  .saved-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 24px var(--pad-x) 80px;
  }
  .saved-page-head {
    margin-bottom: 24px;
  }
  .saved-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
    text-decoration: none;
    margin-bottom: 14px;
  }
  .saved-back:hover { color: var(--navy); }
  .saved-page h1 {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .saved-empty {
    margin: 48px 0;
    text-align: center;
    color: var(--muted-2);
  }
  .saved-empty h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .saved-empty p {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 auto;
    max-width: 360px;
  }

  .saved-group { margin-top: 26px; }
  .saved-group-head {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-2);
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 1px dotted var(--rule-strong);
  }

  .saved-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
    position: relative;
  }
  .saved-item:last-child { border-bottom: none; }
  .saved-item-cat {
    grid-column: 1;
    grid-row: 1;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7a2e3b;
    margin-bottom: 4px;
  }
  .saved-item-title {
    grid-column: 1;
    grid-row: 2;
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.3;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.005em;
  }
  .saved-item-date {
    display: none; /* date is implied by the group header — keep card clean */
  }
  .saved-item-remove {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: start;
    justify-self: end;
    margin-top: 2px;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; border: none; padding: 0;
    color: #7a2e3b;
    cursor: pointer;
  }
  .saved-item-remove svg { width: 18px; height: 18px; }
  .saved-item-remove:hover { color: var(--navy); }

  @media (max-width: 640px) {
    .saved-page { padding: 18px 18px 90px; }
    .saved-page h1 { font-size: 24px; }
    .saved-item-title { font-size: 16px; }
  }
</style>
