---
// Vertical share strip for article pages.
//
// Renders four share buttons (X · LinkedIn · Email · Copy link) on the
// left, plus a Save (bookmark) button on the right. Share URLs are built
// client-side from window.location.href so they always reflect the
// current page without us having to plumb a URL through props or rely on
// Astro.site being set. The Save button persists to localStorage under
// the key `delfineo:saved` (array of { slug, savedAt }).
//
// Usage: <ShareStrip lang="en" slug="20260427-01-central-banks-hold" />
const { lang = 'en', slug = '' } = Astro.props;

const L = {
  en: {
    share: 'Share',
    x: 'Share on X',
    linkedin: 'Share on LinkedIn',
    email: 'Share via email',
    copy: 'Copy link',
    copied: 'Copied',
    save: 'Save for later',
    saved: 'Saved',
  },
  fr: {
    share: 'Partager',
    x: 'Partager sur X',
    linkedin: 'Partager sur LinkedIn',
    email: 'Partager par email',
    copy: 'Copier le lien',
    copied: 'Copié',
    save: 'Sauvegarder',
    saved: 'Sauvegardé',
  },
}[lang] || null;
---

<aside class="share-strip" aria-label={L.share}>
  <span class="share-label">{L.share}</span>

  <a href="#" data-share="x" target="_blank" rel="noopener" class="share-btn" aria-label={L.x} title={L.x}>
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644Z"/>
    </svg>
  </a>

  <a href="#" data-share="linkedin" target="_blank" rel="noopener" class="share-btn" aria-label={L.linkedin} title={L.linkedin}>
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.777 13.019H3.555V9h3.559v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>

  <a href="#" data-share="email" class="share-btn" aria-label={L.email} title={L.email}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,13 2,6"/>
    </svg>
  </a>

  <button type="button" class="share-btn share-copy" aria-label={L.copy} title={L.copy} data-copied-label={L.copied}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="icon-link">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    </svg>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="icon-check">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </button>

  <!-- Save button — pushed to the right edge of the strip via margin-left:auto -->
  <button
    type="button"
    class="share-btn share-save"
    data-save-btn
    data-slug={slug}
    data-label-save={L.save}
    data-label-saved={L.saved}
    aria-label={L.save}
    title={L.save}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="icon-bookmark">
      <path d="M6 4h12v17l-6-4-6 4z"/>
    </svg>
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="icon-bookmark-filled">
      <path d="M6 4h12v17l-6-4-6 4z"/>
    </svg>
  </button>
</aside>

<script is:inline>
  (function () {
    const strip = document.querySelector('.share-strip');
    if (!strip) return;

    const url = window.location.href;
    const title = document.title.replace(/\s*—\s*Delfineo\s*$/, '');
    const encodedUrl = encodeURIComponent(url);
    const encodedTitle = encodeURIComponent(title);

    strip.querySelectorAll('[data-share]').forEach((a) => {
      const type = a.dataset.share;
      if (type === 'x') {
        a.href = `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`;
      } else if (type === 'linkedin') {
        a.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
      } else if (type === 'email') {
        a.href = `mailto:?subject=${encodedTitle}&body=${encodedUrl}`;
      }
    });

    const copyBtn = strip.querySelector('.share-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        const confirmState = () => {
          const originalTitle = copyBtn.title;
          copyBtn.classList.add('copied');
          copyBtn.title = copyBtn.dataset.copiedLabel || 'Copied';
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            copyBtn.title = originalTitle;
          }, 1600);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(confirmState).catch(() => {
            // Fallback below
            fallback();
          });
        } else {
          fallback();
        }
        function fallback() {
          const temp = document.createElement('input');
          temp.value = url;
          document.body.appendChild(temp);
          temp.select();
          try { document.execCommand('copy'); confirmState(); } catch (e) { /* noop */ }
          document.body.removeChild(temp);
        }
      });
    }

    // Save / unsave — persisted in localStorage under `delfineo:saved`
    // as an array of { slug, savedAt } objects. Slug is language-agnostic
    // (no en/ or fr/ prefix) so the saved page can render in either
    // language regardless of where the article was saved.
    const saveBtn = strip.querySelector('[data-save-btn]');
    const SLUG = saveBtn && saveBtn.dataset.slug;
    if (saveBtn && SLUG) {
      const KEY = 'delfineo:saved';
      const readList = () => {
        try { return JSON.parse(localStorage.getItem(KEY) || '[]') || []; }
        catch (_) { return []; }
      };
      const writeList = (list) => {
        try { localStorage.setItem(KEY, JSON.stringify(list)); } catch (_) {}
      };
      const isSaved = () => readList().some((it) => it && it.slug === SLUG);
      const paint = () => {
        const on = isSaved();
        saveBtn.classList.toggle('saved', on);
        saveBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
        const label = on
          ? (saveBtn.dataset.labelSaved || 'Saved')
          : (saveBtn.dataset.labelSave  || 'Save for later');
        saveBtn.setAttribute('aria-label', label);
        saveBtn.title = label;
      };
      saveBtn.addEventListener('click', () => {
        const list = readList();
        const idx  = list.findIndex((it) => it && it.slug === SLUG);
        if (idx >= 0) list.splice(idx, 1);
        else list.push({ slug: SLUG, savedAt: Date.now() });
        writeList(list);
        paint();
      });
      paint();
    }
  })();
</script>
