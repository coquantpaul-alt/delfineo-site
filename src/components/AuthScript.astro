---
// Client-side auth glue.
// - Calls /api/auth/me on load.
// - If signed in: adds body.is-signed-in (CSS removes paywall + mask).
// - Sign-up button [data-subscribe] still opens the modal.
// - Inline paywall forms ([data-paywall-form]) post to /api/auth/request
//   and flip the surrounding card to a "check your inbox" state.
// - The old click-block on [data-gated] is gone — articles always navigate.
---
<script>
  const AUTH_BASE = '/api/auth';

  const overlay      = document.getElementById('auth-overlay');
  const emailInput   = document.getElementById('auth-email');
  const authBtn      = document.getElementById('auth-btn');
  const authClose    = document.getElementById('auth-close');
  const authError    = document.getElementById('auth-error');
  const authForm     = document.getElementById('auth-form-state');
  const authSuccess  = document.getElementById('auth-success-state');
  const successTitle = document.getElementById('success-title');
  const successMsg   = document.getElementById('success-msg');

  const subBtns      = document.querySelectorAll('[data-subscribe]');
  const userArea     = document.getElementById('user-area');
  const userAreaMob  = document.getElementById('user-area-mobile');

  let me = null;

  async function fetchMe() {
    try {
      const r = await fetch(AUTH_BASE + '/me', { credentials: 'include' });
      if (!r.ok) return null;
      const j = await r.json();
      return j.status === 'ok' ? j : null;
    } catch (_) { return null; }
  }

  function showUserBadge() {
    if (!me) return;
    const name = me.email.split('@')[0];
    const safeName = escapeHtml(name);

    // Desktop badge — name + sign-out button
    if (userArea) {
      userArea.innerHTML =
        '<span class="name"><span class="dot"></span>' + safeName + '</span>' +
        '<button class="sign-out" id="sign-out-btn">' + (userArea.dataset.signout || 'Sign out') + '</button>';
      userArea.style.display = '';
      const out = document.getElementById('sign-out-btn');
      if (out) out.addEventListener('click', signOut);
    }

    // Mobile badge — name + green dot only (no sign-out chip)
    if (userAreaMob) {
      userAreaMob.innerHTML =
        '<span class="name"><span class="dot"></span>' + safeName + '</span>';
      userAreaMob.style.display = '';
    }

    // Hide all "subscribe / sign in" CTAs (desktop + mobile)
    subBtns.forEach((b) => b.style.display = 'none');
  }

  async function signOut() {
    await fetch(AUTH_BASE + '/logout', { method: 'POST', credentials: 'include' });
    me = null;
    location.reload();
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
  }

  /* ── modal (Subscribe button only) ───────────────────────────── */
  function openModal() {
    if (!overlay) return;
    overlay.style.display = 'flex';
    if (authForm) authForm.style.display = 'block';
    if (authSuccess) authSuccess.style.display = 'none';
    if (authError) authError.textContent = '';
    if (emailInput) {
      emailInput.value = '';
      setTimeout(() => emailInput.focus(), 10);
    }
  }
  function closeModal() {
    if (!overlay) return;
    overlay.style.display = 'none';
  }

  async function requestModalLink() {
    const email = (emailInput?.value || '').trim().toLowerCase();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (authError) authError.textContent = authError.dataset.emailError || 'Please enter a valid email.';
      return;
    }
    authBtn.disabled = true;
    authBtn.textContent = authBtn.dataset.checking || 'Sending…';
    if (authError) authError.textContent = '';
    try {
      const r = await fetch(AUTH_BASE + '/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, redirectTo: location.pathname + location.search }),
      });
      const j = await r.json().catch(() => ({}));
      if (!r.ok) {
        if (authError) authError.textContent = j.message || 'Something went wrong. Please try again.';
        return;
      }
      if (authForm) authForm.style.display = 'none';
      if (authSuccess) authSuccess.style.display = 'block';
      if (successTitle) successTitle.textContent = j.alreadyMember
        ? (successTitle.dataset.existing || 'Welcome back')
        : (successTitle.dataset.new || 'Check your inbox');
      if (successMsg) {
        const tpl = j.alreadyMember
          ? (successMsg.dataset.existing || 'We just sent a sign-in link to %EMAIL%.')
          : (successMsg.dataset.new || 'We just sent a sign-in link to %EMAIL%.');
        successMsg.textContent = tpl.replace('%EMAIL%', email);
      }
    } catch (_) {
      if (authError) authError.textContent = 'Connection error. Please try again.';
    } finally {
      authBtn.disabled = false;
      authBtn.textContent = authBtn.dataset.label || 'Continue';
    }
  }

  /* ── inline paywall (article body) ───────────────────────────── */
  async function handlePaywallSubmit(form) {
    const cta = form.closest('.paywall-cta');
    const input = form.querySelector('input[name="email"]');
    const btn = form.querySelector('button');
    const errEl = cta.querySelector('.err');
    const email = (input.value || '').trim().toLowerCase();

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (errEl) errEl.textContent = 'Please enter a valid email.';
      return;
    }
    if (errEl) errEl.textContent = '';
    btn.disabled = true;
    const originalLabel = btn.textContent;
    btn.textContent = 'Sending…';

    try {
      const r = await fetch(AUTH_BASE + '/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ email, redirectTo: location.pathname + location.search }),
      });
      const j = await r.json().catch(() => ({}));
      if (!r.ok) {
        if (errEl) errEl.textContent = j.message || 'Something went wrong. Please try again.';
        btn.disabled = false;
        btn.textContent = originalLabel;
        return;
      }
      // Replace inner with success message — bilingual
      cta.classList.add('success');
      var pageLang = (document.documentElement.lang || 'en').toLowerCase();
      var copy = pageLang === 'fr'
        ? {
            label: j.alreadyMember ? 'Content de vous revoir' : 'Verifiez votre boite mail',
            h3:    'Nous venons d\u2019envoyer un lien de connexion a ' + escapeHtml(email),
            body:  'Cliquez sur le lien dans votre boite mail sous 15 minutes pour debloquer cet article et tous les suivants.',
            hint:  'Gratuit \u00b7 Pas de spam \u00b7 Lien magique',
          }
        : {
            label: j.alreadyMember ? 'Welcome back' : 'Check your inbox',
            h3:    'We just sent a sign-in link to ' + escapeHtml(email),
            body:  'Click the link in your inbox within 15 minutes to unlock this article and every future one.',
            hint:  'Free \u00b7 No spam \u00b7 Magic-link sign-in',
          };
      cta.innerHTML =
        '<p class="label">\u2014 ' + copy.label + '</p>' +
        '<h3>' + copy.h3 + '</h3>' +
        '<p>' + copy.body + '</p>' +
        '<p class="hint">' + copy.hint + '</p>';
    } catch (_) {
      if (errEl) errEl.textContent = 'Connection error. Please try again.';
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  }

  /* ── wire up ─────────────────────────────────────────────────── */
  subBtns.forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); openModal(); }));
  authClose?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  authBtn?.addEventListener('click', requestModalLink);
  emailInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') requestModalLink(); });

  document.addEventListener('submit', (e) => {
    const form = e.target.closest('[data-paywall-form]');
    if (form) { e.preventDefault(); handlePaywallSubmit(form); }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay && overlay.style.display !== 'none') closeModal();
  });

  /* ── saved-articles cross-device sync ────────────────────────── */
  // Strategy: localStorage stays the local source of truth, so the
  // /saved/ page renders instantly without waiting on a network call.
  // On every page load (when signed in) we fetch the cloud list,
  // merge with localStorage by slug (newer savedAt wins), write the
  // result back to localStorage, then push any local-only items to
  // the cloud so a user's pre-sign-in saves aren't lost. After the
  // merge we dispatch `delfineo:saved-synced` so the saved-page
  // script re-renders with the freshest data.
  const SAVED_KEY = 'delfineo:saved';

  function readLocalSaved() {
    try { return JSON.parse(localStorage.getItem(SAVED_KEY) || '[]') || []; }
    catch (_) { return []; }
  }
  function writeLocalSaved(list) {
    try { localStorage.setItem(SAVED_KEY, JSON.stringify(list)); } catch (_) {}
  }

  async function syncSaved() {
    let cloud = [];
    try {
      const r = await fetch(AUTH_BASE + '/saved', { credentials: 'include' });
      if (!r.ok) return;
      const j = await r.json().catch(() => ({}));
      cloud = Array.isArray(j.items) ? j.items : [];
    } catch (_) { return; }

    const local = readLocalSaved();
    const map = Object.create(null);
    cloud.forEach((it) => {
      if (it && it.slug) map[it.slug] = { slug: it.slug, savedAt: Number(it.savedAt) || 0 };
    });
    const localOnly = [];
    local.forEach((it) => {
      if (!it || !it.slug) return;
      const existing = map[it.slug];
      const ts = Number(it.savedAt) || 0;
      if (!existing) {
        map[it.slug] = { slug: it.slug, savedAt: ts };
        localOnly.push(map[it.slug]);
      } else if (ts > existing.savedAt) {
        map[it.slug] = { slug: it.slug, savedAt: ts };
      }
    });

    const merged = Object.values(map).sort((a, b) => b.savedAt - a.savedAt);
    writeLocalSaved(merged);

    // Push local-only saves up to the cloud (best-effort, fire-and-forget)
    if (localOnly.length) {
      await Promise.all(localOnly.map((it) =>
        fetch(AUTH_BASE + '/saved', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ slug: it.slug, savedAt: it.savedAt }),
        }).catch(() => {})
      ));
    }

    document.dispatchEvent(new CustomEvent('delfineo:saved-synced', {
      detail: { items: merged }
    }));
  }

  /* ── init ────────────────────────────────────────────────────── */
  (async () => {
    me = await fetchMe();
    if (me) {
      document.body.classList.add('is-signed-in');
      showUserBadge();
      syncSaved(); // fire-and-forget; saved page listens for the event
    }
  })();
</script>
