---
// News lead-story hero with navy "Key Takeaway" sidecar.
import Tag from './Tag.astro';

interface Story {
  slug: string;
  data: {
    title: string;
    category: string;
    date: string;
    dateDisplay: string;
    summary: string;
    insight?: string;
  };
}
interface Props {
  story: Story;
  lang?: 'en' | 'fr';
  sourceLabel?: string;
  readMinutes?: number;
  takeawayBullets?: string[];
}
const { story, lang = 'en', sourceLabel, readMinutes, takeawayBullets } = Astro.props;

const leadLabel = lang === 'fr' ? 'A la une' : 'Lead Story';
const mins = readMinutes || 4;
const readLabel = lang === 'fr' ? (mins + ' min de lecture') : (mins + ' min read');
const ctaLabel  = lang === 'fr' ? "Lire l'article ->" : 'Read the brief ->';
const takeLabel = lang === 'fr' ? "Ce qu'il faut retenir" : 'Key Takeaway';

const dek = story.data.summary
  .replace(/\*\*(.+?)\*\*/g, '$1')
  .replace(/\*(.+?)\*/g, '$1')
  .replace(/_([^_]+)_/g, '$1')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 400);

const slugNoLang = story.slug.replace(lang + '/', '');
const href = '/' + lang + '/news/' + slugNoLang + '/';

// ── Pull-quote fallback (used by the aside when the parent provides
// no chart and the story has no insight). Picks the most "fact-dense"
// sentence from the summary — i.e. the one with the highest density
// of digits and % signs, between 60 and 220 characters. Falls back to
// the first sentence. Never throws on weird input.
function pickPullQuote(rawSummary: string): string {
  const cleaned = rawSummary
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/_([^_]+)_/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();
  // Drop a trailing source attribution if present
  const noSrc = cleaned.replace(/\s*Source\s*:.+$/i, '').replace(/\s*Sources\s*:.+$/i, '');
  // Split into sentences (.+? then [.?!] then space or end)
  const sentences = noSrc.match(/[^.!?]+[.!?]+(?=\s|$)/g) || [noSrc];
  let best = sentences[0]?.trim() || cleaned.slice(0, 220);
  let bestScore = -Infinity;
  for (const s of sentences) {
    const t = s.trim();
    if (t.length < 60 || t.length > 240) continue;
    const digits = (t.match(/\d/g) || []).length;
    const pcts = (t.match(/%/g) || []).length;
    const score = digits * 1.0 + pcts * 2.0 - Math.max(0, t.length - 180) * 0.05;
    if (score > bestScore) { bestScore = score; best = t; }
  }
  // Cap length to keep the card tidy
  if (best.length > 220) best = best.slice(0, 217).replace(/[\s,;:—–-]+$/, '') + '…';
  return best;
}
const pullQuote = pickPullQuote(story.data.summary);
const inLabel = lang === 'fr' ? 'Extrait' : 'Pull quote';
---
<section class="editorial-hero">
  <div>
    <Tag>{leadLabel} &middot; {story.data.category.toUpperCase()}</Tag>
    <h1><a href={href}>{story.data.title}</a></h1>
    <p class="dek">{dek}</p>
    <div class="meta-row">
      {sourceLabel && (
        <span class="source-meta">
          <span>{sourceLabel}</span>
          <span class="sep">&middot;</span>
        </span>
      )}
      <span>{story.data.dateDisplay}</span>
      <span class="sep">&middot;</span>
      <span>{readLabel}</span>
      <a class="cta" href={href}>{ctaLabel}</a>
    </div>
  </div>

  <slot name="aside">
    {story.data.insight ? (
      <aside class="takeaway-card" aria-label={takeLabel}>
        <div class="label">&mdash; {takeLabel}</div>
        <p class="headline">{story.data.insight.replace(/\s+/g, ' ').trim()}</p>
        {takeawayBullets && takeawayBullets.length > 0 && (
          <div class="bullets-wrap">
            <div class="sep"></div>
            <ul>
              {takeawayBullets.map((b) => (
                <li><span class="bullet">&mdash;</span><span>{b}</span></li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    ) : (
      <aside class="hero-pullquote" aria-label={inLabel}>
        <div class="label">&mdash; {inLabel}</div>
        <p class="quote">{pullQuote}</p>
        <p class="attribution">{story.data.dateDisplay} &middot; {story.data.category}</p>
      </aside>
    )}
  </slot>
</section>
