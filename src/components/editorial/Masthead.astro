---
import Monogram from './Monogram.astro';
import { t } from '../../i18n.js';

interface Props {
  lang?: 'en' | 'fr';
  active?: 'news' | 'research' | 'saved' | 'search' | null;
  newsCount?: number | null;
  researchCount?: number | null;
  altPath?: string;
  showSubscribe?: boolean;
}

const {
  lang = 'en',
  active = 'news',
  newsCount = null,
  researchCount = null,
  altPath,
  showSubscribe = true,
} = Astro.props;

const i = (k: string) => t(lang, k);

// Today's date strip (left side)
const now = new Date();
const dayNames = {
  en: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
  fr: ['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'],
};
const monthNames = {
  en: ['January','February','March','April','May','June','July','August','September','October','November','December'],
  fr: ['janvier','fevrier','mars','avril','mai','juin','juillet','aout','septembre','octobre','novembre','decembre'],
};
const dateLabel = lang === 'fr'
  ? (dayNames.fr[now.getDay()] + ' - ' + now.getDate() + ' ' + monthNames.fr[now.getMonth()] + ' ' + now.getFullYear())
  : (dayNames.en[now.getDay()] + ' - ' + monthNames.en[now.getMonth()] + ' ' + now.getDate() + ', ' + now.getFullYear());

const searchPlaceholder = lang === 'fr' ? 'Rechercher...' : 'Search stories...';
const altLang = lang === 'en' ? 'fr' : 'en';
const altHref = altPath || ('/' + altLang + '/');
---
<header class="masthead">
  <!-- Nameplate row with date on the left -->
  <div class="nameplate nameplate-slim">
    <div class="left">
      <span class="date-label">{dateLabel}</span>
      <button
        type="button"
        class="search-icon-btn"
        aria-label="Search"
        data-open-search
      >
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4" />
          <path d="M11 11 L14 14" stroke="currentColor" stroke-width="1.4" />
        </svg>
      </button>

      <!-- Mobile-only sign-in / user badge (hidden on desktop) -->
      <span
        class="user-badge user-badge-mobile"
        id="user-area-mobile"
        data-signout={i('signOut')}
        style="display:none"
      ></span>
      <button class="btn-signin-mobile" data-subscribe>
        {lang === 'fr' ? 'CONNEXION' : 'SIGN IN'}
      </button>
    </div>

    <a href={`/${lang}/`} class="center" aria-label="Delfineo home">
      <Monogram variant="seal" size={34} />
      <span style="display:flex;flex-direction:column;align-items:center;">
        <span class="wordmark">DELFINEO</span>
        <span class="tagline">{i('tagline')}</span>
      </span>
    </a>

    <div class="right">
      <span class="lang-toggle" aria-label="Language">
        <a href="/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
        <span class="lang-sep">/</span>
        <a href={altHref} class={lang === 'fr' ? 'active' : ''}>FR</a>
      </span>
      <button class="search-pill" type="button" aria-label="Search" data-open-search>
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" />
          <path d="M11 11 L14 14" stroke="currentColor" stroke-width="1.2" />
        </svg>
        <span style="flex:1;text-align:left">{searchPlaceholder}</span>
        <span class="kbd">&#8984;K</span>
      </button>
    </div>
  </div>

  <!-- Nav -->
  <nav class="masthead-nav" role="tablist" aria-label="Sections">
    <button
      class={`tab-btn ${active === 'news' ? 'active' : ''}`}
      id="tab-news"
      onclick="showTab('news')"
      role="tab"
      aria-selected={active === 'news'}
    >
      {i('news')}
      {newsCount !== null && newsCount !== undefined && newsCount > 0 && (
        <sup>{newsCount}</sup>
      )}
    </button>
    <button
      class={`tab-btn ${active === 'research' ? 'active' : ''}`}
      id="tab-research"
      onclick="showTab('research')"
      role="tab"
      aria-selected={active === 'research'}
    >
      {i('research')}
      {researchCount !== null && researchCount !== undefined && researchCount > 0 && (
        <sup>{researchCount}</sup>
      )}
    </button>

    {showSubscribe && (
      <span
        style="position:absolute;right:var(--pad-x);display:flex;align-items:center;gap:14px;"
        id="masthead-right-rail"
      >
        <span id="user-area" class="user-badge" data-signout={i('signOut')} style="display:none"></span>
        <button class="btn-subscribe" data-subscribe>{i('subscribe')}</button>
      </span>
    )}
  </nav>
</header>

<style>
  .masthead-nav { position: relative; }
  .nameplate-slim { grid-template-columns: 1fr auto 1fr; }
  .nameplate .left {
    display: flex;
    align-items: flex-end;
    padding-bottom: 6px;
  }
  .date-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .nameplate .right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .lang-toggle a {
    color: var(--muted);
    text-decoration: none;
    padding: 1px 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .lang-toggle a:hover { color: var(--navy); }
  .lang-toggle a.active {
    color: var(--navy);
    border-bottom-color: var(--navy);
  }
  .lang-toggle .lang-sep { color: var(--rule-strong); }
  @media (max-width: 900px) {
    #masthead-right-rail { display: none !important; }
    .nameplate-slim .right .search-pill { min-width: 140px; }
  }
  @media (max-width: 640px) {
    .nameplate-slim { grid-template-columns: 1fr; }
    .nameplate-slim .left { justify-content: center; padding-bottom: 0; margin-bottom: 8px; }
    .nameplate-slim .right { display: flex; justify-content: center; margin-top: 12px; }
    .nameplate-slim .right .search-pill { display: none; }
    .date-label { font-size: 9px; letter-spacing: 0.14em; }
  }
</style>

<script is:inline>
  // Make the News/Research nav buttons work on every page.
  // On the home page (where #panel-news and #panel-research exist), toggle them.
  // On any other page (article pages), navigate to /lang/?tab=...
  window.showTab = function(tab) {
    var news = document.getElementById('panel-news');
    var research = document.getElementById('panel-research');
    if (news && research) {
      news.style.display = tab === 'news' ? 'block' : 'none';
      research.style.display = tab === 'research' ? 'block' : 'none';
      var bn = document.getElementById('tab-news');
      var br = document.getElementById('tab-research');
      if (bn) bn.classList.toggle('active', tab === 'news');
      if (br) br.classList.toggle('active', tab === 'research');
      try {
        var u = new URL(window.location);
        u.searchParams.set('tab', tab);
        history.replaceState(null, '', u);
      } catch (_) {}
    } else {
      var lang = document.documentElement.lang || 'en';
      window.location.href = '/' + lang + '/?tab=' + tab;
    }
  };
</script>
