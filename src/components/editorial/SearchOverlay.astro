---
// Site-wide search modal. Opens on:
//   - click of any element with class .search-pill or [data-open-search]
//   - keyboard shortcut Cmd/Ctrl+K
//   - keyboard shortcut / (when not typing in a form)
// Closes on Esc, backdrop click, or the X button.
// Live filter against /search-<lang>.json. No backend required.
interface Props { lang?: 'en' | 'fr'; }
const { lang = 'en' } = Astro.props;

const L = lang === 'fr'
  ? {
      placeholder: 'Rechercher des articles, des analyses, des entreprises...',
      empty: 'Aucun resultat.',
      news: 'Actualites',
      research: 'Recherche',
      hint: 'entree pour ouvrir, echap pour fermer',
      kbd: 'ESC',
      title: 'Rechercher',
    }
  : {
      placeholder: 'Search stories, analyses, companies...',
      empty: 'No results.',
      news: 'News',
      research: 'Research',
      hint: 'enter to open, esc to close',
      kbd: 'ESC',
      title: 'Search',
    };
---
<div id="search-overlay" class="search-overlay" data-lang={lang} aria-hidden="true" style="display:none">
  <div class="search-modal" role="dialog" aria-modal="true" aria-label={L.title}>
    <div class="search-input-row">
      <svg class="search-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"></circle>
        <path d="M11 11 L14.5 14.5" stroke="currentColor" stroke-width="1.3"></path>
      </svg>
      <input
        id="search-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder={L.placeholder}
        aria-label={L.title}
      />
      <button type="button" id="search-close" class="search-close" aria-label="Close">{L.kbd}</button>
    </div>
    <div class="search-status" id="search-status" aria-live="polite"></div>
    <div class="search-results" id="search-results" role="listbox"></div>
    <div class="search-footer">
      <span>{L.hint}</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ labels: L, lang }}>
  (function () {
    const overlay = document.getElementById('search-overlay');
    const input   = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const status  = document.getElementById('search-status');
    const closeBtn= document.getElementById('search-close');
    if (!overlay || !input || !results) return;

    let INDEX = null;
    let activeIndex = -1;
    let currentHits = [];

    async function loadIndex() {
      if (INDEX) return INDEX;
      try {
        const res = await fetch('/search-' + lang + '.json', { cache: 'force-cache' });
        INDEX = await res.json();
      } catch (e) {
        INDEX = [];
      }
      return INDEX;
    }

    function open() {
      overlay.style.display = 'flex';
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      loadIndex().then(() => { render(input.value); });
      setTimeout(() => input.focus(), 10);
    }

    function close() {
      overlay.style.display = 'none';
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      activeIndex = -1;
    }

    function highlight(text, terms) {
      if (!terms.length) return escapeHtml(text);
      let out = escapeHtml(text);
      terms.forEach((t) => {
        if (!t) return;
        const rx = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        out = out.replace(rx, '<mark>$1</mark>');
      });
      return out;
    }

    function escapeHtml(s) {
      return (s || '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function score(entry, terms) {
      let s = 0;
      const title = (entry.title || '').toLowerCase();
      const sum   = (entry.summary || '').toLowerCase();
      const cat   = (entry.category || '').toLowerCase();
      for (const t of terms) {
        if (!t) continue;
        if (title.includes(t)) s += 10;
        if (cat === t)         s += 6;
        if (cat.includes(t))   s += 3;
        if (sum.includes(t))   s += 2;
      }
      return s;
    }

    function render(query) {
      const q = (query || '').trim().toLowerCase();
      const terms = q ? q.split(/\s+/) : [];

      // Empty query: keep the overlay minimal, no result list
      if (!terms.length) {
        currentHits = [];
        activeIndex = -1;
        status.textContent = '';
        results.innerHTML = '';
        return;
      }

      const hits = (INDEX || [])
        .map((e) => ({ e, s: score(e, terms) }))
        .filter((x) => x.s > 0)
        .sort((a, b) => b.s - a.s || (b.e.date || '').localeCompare(a.e.date || ''))
        .slice(0, 5)
        .map((x) => x.e);

      currentHits = hits;
      activeIndex = hits.length ? 0 : -1;

      status.textContent = hits.length === 0
        ? labels.empty
        : (lang === 'fr'
            ? (hits.length === 1 ? '1 resultat' : hits.length + ' resultats')
            : (hits.length === 1 ? '1 result'   : hits.length + ' results'));

      if (!hits.length) {
        results.innerHTML = '<div class="search-empty">' + labels.empty + '</div>';
        return;
      }

      const newsHits = hits.filter((h) => h.kind === 'news');
      const resHits  = hits.filter((h) => h.kind === 'research');

      let html = '';
      if (resHits.length) {
        html += '<div class="search-group">' + labels.research + '</div>';
        resHits.forEach((h) => { html += resultRow(h, terms); });
      }
      if (newsHits.length) {
        html += '<div class="search-group">' + labels.news + '</div>';
        newsHits.forEach((h) => { html += resultRow(h, terms); });
      }
      results.innerHTML = html;
      updateActive();
    }

    function resultRow(h, terms) {
      const meta = [h.category, h.dateDisplay || h.date].filter(Boolean).join(' \u00b7 ');
      return (
        '<a class="search-result" href="' + escapeHtml(h.url) + '" role="option">'
          + '<div class="sr-meta">' + escapeHtml(meta) + '</div>'
          + '<div class="sr-title">' + highlight(h.title, terms) + '</div>'
          + '<div class="sr-summary">' + highlight(h.summary || '', terms) + '</div>'
        + '</a>'
      );
    }

    function updateActive() {
      const rows = results.querySelectorAll('.search-result');
      rows.forEach((r, i) => r.classList.toggle('active', i === activeIndex));
      const el = rows[activeIndex];
      if (el) el.scrollIntoView({ block: 'nearest' });
    }

    input.addEventListener('input', (e) => render(e.target.value));
    input.addEventListener('keydown', (e) => {
      const rows = results.querySelectorAll('.search-result');
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, rows.length - 1); updateActive(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); updateActive(); }
      else if (e.key === 'Enter') {
        const el = rows[activeIndex];
        if (el) { e.preventDefault(); window.location.href = el.getAttribute('href'); }
      } else if (e.key === 'Escape') { e.preventDefault(); close(); }
    });

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    // Global: Cmd/Ctrl+K opens, "/" opens (when not typing), Esc closes
    document.addEventListener('keydown', (e) => {
      const typing = /^(INPUT|TEXTAREA|SELECT)$/.test((e.target && e.target.tagName) || '') || (e.target && e.target.isContentEditable);
      if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) { e.preventDefault(); open(); return; }
      if (e.key === '/' && !typing && overlay.style.display === 'none') { e.preventDefault(); open(); return; }
      if (e.key === 'Escape' && overlay.style.display !== 'none') { close(); return; }
    });

    // Click handlers on the pill and any [data-open-search]
    document.addEventListener('click', (e) => {
      const t = e.target.closest('.search-pill, [data-open-search]');
      if (t) { e.preventDefault(); open(); }
    });
  })();
</script>

<style is:global>
  .search-overlay {
    position: fixed; inset: 0; z-index: 1100;
    background: rgba(14, 23, 38, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: flex-start; justify-content: center;
    padding: 12vh 24px 24px;
    animation: fadeIn 0.15s ease;
  }
  .search-modal {
    width: 100%; max-width: 640px;
    background: var(--paper);
    border: 1px solid var(--rule);
    box-shadow: 0 24px 64px rgba(14, 23, 38, 0.22);
    display: flex; flex-direction: column;
    max-height: 75vh;
    animation: fadeInUp 0.2s ease;
  }
  .search-input-row {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px;
    border-bottom: 1px solid var(--rule);
  }
  .search-icon { width: 14px; height: 14px; color: var(--muted); flex-shrink: 0; }
  #search-input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--ink);
    padding: 4px 0;
  }
  #search-input::placeholder { color: var(--muted); font-style: italic; }
  .search-close {
    border: 1px solid var(--rule);
    background: transparent;
    padding: 3px 8px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    color: var(--muted);
    cursor: pointer;
    border-radius: 0;
  }
  .search-close:hover { color: var(--navy); border-color: var(--navy); }

  .search-status {
    padding: 10px 18px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--rule);
    min-height: 10px;
  }
  .search-status:empty { display: none; }

  .search-results {
    flex: 1;
    overflow-y: auto;
    padding: 4px 0;
  }
  .search-group {
    padding: 14px 18px 6px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
  .search-result {
    display: block;
    padding: 12px 18px;
    text-decoration: none;
    color: inherit;
    border-left: 2px solid transparent;
    transition: background 0.1s, border-color 0.1s;
  }
  .search-result:hover,
  .search-result.active {
    background: rgba(10, 37, 64, 0.05);
    border-left-color: var(--navy);
  }
  .sr-meta {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .sr-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .sr-summary {
    margin-top: 4px;
    font-family: var(--font-serif);
    font-size: 13px;
    line-height: 1.5;
    color: var(--muted-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sr-title mark,
  .sr-summary mark {
    background: rgba(255, 221, 130, 0.55);
    color: inherit;
    padding: 0 1px;
  }

  .search-empty {
    padding: 24px 18px;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--muted);
    text-align: center;
  }
  .search-footer {
    padding: 10px 18px;
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
  }

  @media (max-width: 640px) {
    .search-overlay { padding: 4vh 12px 12px; align-items: flex-start; }
    .search-modal { max-height: 92vh; }
    #search-input { font-size: 16px; }
    .sr-title { font-size: 15px; }
  }
</style>
